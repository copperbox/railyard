{
  "name": "railyard-monorepo",
  "private": true,
  "packageManager": "pnpm@11.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:docker": "pnpm -r --workspace-concurrency=1 test:docker",
    "test:llm": "pnpm -r --workspace-concurrency=1 test:llm"
  }
}
