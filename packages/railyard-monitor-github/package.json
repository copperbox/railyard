{
  "name": "@copperbox/railyard-monitor-github",
  "version": "1.0.0",
  "description": "First-party GitHub issues monitor for railyard: polls issue events, emits github.issue.* signals with published JSON Schemas.",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/copperbox/railyard.git",
    "directory": "packages/railyard-monitor-github"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schemas/*": "./schemas/*"
  },
  "files": [
    "dist",
    "schemas"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:docker": "cross-env RAILYARD_DOCKER_TESTS=1 vitest run",
    "test:github": "cross-env RAILYARD_GITHUB_TESTS=1 vitest run"
  },
  "peerDependencies": {
    "@copperbox/railyard": "^1.0.0"
  },
  "devDependencies": {
    "@copperbox/railyard": "workspace:*",
    "@types/node": "^26.0.0",
    "cross-env": "^10.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  }
}
